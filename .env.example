# ============================================
# MISTRAL AI CONFIGURATION
# ============================================
# Get your free API key from: https://console.mistral.ai/
# Sign up for free and generate an API key
MISTRAL_API_KEY=your_mistral_api_key_here

# ============================================
# OPENWEATHER API CONFIGURATION
# ============================================
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ============================================
# NEWS DATA API CONFIGURATION
# ============================================
# Get your free API key from: https://newsdata.io/
NEWSDATA_API_KEY=your_newsdata_api_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite database file path
DB_PATH=./data/air_quality.db

# ============================================
# RASPBERRY PI GPIO SENSOR CONFIGURATION
# ============================================
# DHT11 Temperature/Humidity Sensor (GPIO pin)
DHT11_PIN=4

# MQ-135 Air Quality Sensor (GPIO pin)
MQ135_PIN=17

# ============================================
# GPS CONFIGURATION
# ============================================
# Enable/disable GPS module (NEO-6M)
GPS_ENABLED=false

# Default location coordinates if GPS is disabled
DEFAULT_LAT=33.9716
DEFAULT_LON=-6.8498

# ============================================
# FLASK CONFIGURATION
# ============================================
# Flask secret key (change this to a random value in production)
FLASK_SECRET_KEY=your_secret_key_change_me_in_production

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. Never commit this file to git with real API keys
# 2. Add .env to .gitignore
# 3. Share only template with placeholder values
# 4. Each developer should have their own .env
# 5. Production servers should use environment variables
